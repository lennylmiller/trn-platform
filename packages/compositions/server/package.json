  },
  "dependencies": {
    "@trn-platform/shared": "workspace:*",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "4.1.5",
    "supertest": "^7.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "express": "^5.1.0",
    "mssql": "^12.5.0"
  }
}
