    "@tanstack/react-query": "^5.96.2",
    "@testing-library/react": "^16.3.0",
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.9",
    "@mui/icons-material": "^7.3.9",
