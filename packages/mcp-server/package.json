{
  "name": "@trn-platform/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "trn-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external @trn-platform/shared --external @modelcontextprotocol/sdk --external zod --external dotenv --external mssql",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@trn-platform/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "zod": "4.1.12"
  },
  "peerDependencies": {
    "mssql": "^12.5.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "5.9.3"
  }
}
