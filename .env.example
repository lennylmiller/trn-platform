# SQL Server connection (shared across all database pools)
DB_SERVER=localhost
DB_USER=
DB_PASSWORD=
DB_PORT=1433
DB_TRUST_CERT=true

# Named databases (pool names map to env vars: DB_{UPPER_NAME}_DATABASE)
DB_QC_TRAINING_DATABASE=qc_training
DB_QC_CORE_DATABASE=qc_core

# Express server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Auth (set to true for local dev without JWT)
AUTH_DISABLED=true

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
