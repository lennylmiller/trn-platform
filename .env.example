# SQL Server connection (shared across all database pools)
# Leave DB_USER empty to use Windows Authentication (trusted connection)
DB_SERVER=localhost
DB_USER=
DB_PASSWORD=
DB_PORT=1433
DB_TRUST_CERT=true

# Named databases (pool names map to env vars: DB_{UPPER_NAME}_DATABASE)
DB_QC_TRAINING_DATABASE=qc_training
DB_QC_CORE_DATABASE=qc_core

# Express server
PORT=3001
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:6006

# Auth (set to true for local dev without JWT)
AUTH_DISABLED=true

# Shell wrapper script for step execution (routes short commands like "teardown" through qc-train.sh)
# SHELL_WRAPPER=/mnt/c/Users/lmiller/Documents/client-development-tickets/training/QC-Training/qc-train.sh

# Frontend (Vite)
VITE_API_URL=http://localhost:3001

# MCP Server — Express API base URL (used by MCP tools that proxy through the API)
API_URL=http://localhost:3001

# Claude API (for AI Chat in the workbench)
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
